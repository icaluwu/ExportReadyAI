# Copy to .env.local for local development:
#   cp .env.example .env.local

# Supabase (required for auth + database)
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Public site URL for auth email redirects and SEO metadata.
# Local: http://localhost:3000
# Vercel preview: optional — VERCEL_URL is used automatically when unset
# Vercel production: https://export-ready-ai.vercel.app
# Cloud Run: https://YOUR_SERVICE-xxxxx-as.a.run.app
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# Google Gemini (server-only; required for /api/analyze)
GEMINI_API_KEY=your-gemini-api-key

# Supabase service role (server-only; required for payment webhooks & admin writes)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Midtrans payment (server-only except client key)
MIDTRANS_SERVER_KEY=
MIDTRANS_CLIENT_KEY=
MIDTRANS_IS_PRODUCTION=false
NEXT_PUBLIC_MIDTRANS_CLIENT_KEY=
NEXT_PUBLIC_MIDTRANS_IS_PRODUCTION=false

# Skip env validation during build (CI/Docker only — not for production deploys)
# SKIP_ENV_VALIDATION=true
